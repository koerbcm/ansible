services:
  ntfy:
    image: {{ ntfy_image | quote }}
    container_name: {{ ntfy_container_name | quote }}
    command:
      - serve
    environment:
{% for key, value in ntfy_environment | dictsort %}
      {{ key }}: {{ value | string | quote }}
{% endfor %}
    volumes:
      - {{ ntfy_state_dir }}:/var/lib/ntfy
      - {{ ntfy_config_dir }}:/etc/ntfy
    ports:
      - "{{ ntfy_published_port }}:{{ ntfy_container_port }}"
    healthcheck:
      test:
        - CMD-SHELL
        - wget -q --tries=1 http://localhost:{{ ntfy_container_port }}/v1/health -O - | grep -Eo '"healthy"[[:space:]]*:[[:space:]]*true' || exit 1
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 40s
    restart: unless-stopped
