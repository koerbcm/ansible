services:
  {{ invoice_ninja_app_service_name }}:
    image: {{ invoice_ninja_app_image | quote }}
    container_name: {{ invoice_ninja_app_container_name | quote }}
    restart: unless-stopped
    env_file:
      - {{ invoice_ninja_env_file | quote }}
    depends_on:
      {{ invoice_ninja_db_service_name }}:
        condition: service_healthy
      {{ invoice_ninja_redis_service_name }}:
        condition: service_healthy
    volumes:
      - {{ invoice_ninja_data_public_dir | quote }}:/var/www/html/public
      - {{ invoice_ninja_data_storage_dir | quote }}:/var/www/html/storage
    logging:
      driver: {{ invoice_ninja_log_driver | quote }}
{% if invoice_ninja_log_options | length > 0 %}
      options:
{% for key, value in invoice_ninja_log_options.items() %}
        {{ key }}: {{ value | quote }}
{% endfor %}
{% else %}
      options: {}
{% endif %}
{% if invoice_ninja_watchtower_monitor_only | bool %}
    labels:
      com.centurylinklabs.watchtower.monitor-only: "true"
{% endif %}

  {{ invoice_ninja_web_service_name }}:
    image: {{ invoice_ninja_web_image | quote }}
    container_name: {{ invoice_ninja_web_container_name | quote }}
    restart: unless-stopped
    depends_on:
      {{ invoice_ninja_app_service_name }}:
        condition: service_started
    ports:
      - "{{ invoice_ninja_web_published_port }}:80"
    volumes:
      - {{ (invoice_ninja_nginx_conf_dir ~ '/' ~ invoice_ninja_nginx_conf_file) | quote }}:/etc/nginx/conf.d/default.conf:ro
      - {{ invoice_ninja_data_public_dir | quote }}:/var/www/html/public:ro
      - {{ invoice_ninja_data_storage_dir | quote }}:/var/www/html/storage:ro
    logging:
      driver: {{ invoice_ninja_log_driver | quote }}
{% if invoice_ninja_log_options | length > 0 %}
      options:
{% for key, value in invoice_ninja_log_options.items() %}
        {{ key }}: {{ value | quote }}
{% endfor %}
{% else %}
      options: {}
{% endif %}
{% if invoice_ninja_watchtower_monitor_only | bool %}
    labels:
      com.centurylinklabs.watchtower.monitor-only: "true"
{% endif %}

  {{ invoice_ninja_db_service_name }}:
    image: {{ invoice_ninja_db_image | quote }}
    container_name: {{ invoice_ninja_db_container_name | quote }}
    restart: unless-stopped
    env_file:
      - {{ invoice_ninja_env_file | quote }}
{% if invoice_ninja_db_extra_flags | length > 0 %}
    command: {{ invoice_ninja_db_extra_flags | quote }}
{% endif %}
    volumes:
      - {{ invoice_ninja_data_mysql_dir | quote }}:/var/lib/mysql
    healthcheck:
      test: ["CMD-SHELL", "mysqladmin ping -h 127.0.0.1 -uroot -p$${MYSQL_ROOT_PASSWORD}"]
      interval: 15s
      timeout: 5s
      retries: 10
      start_period: 30s
    stop_grace_period: {{ invoice_ninja_db_stop_grace_period | quote }}
    logging:
      driver: {{ invoice_ninja_log_driver | quote }}
{% if invoice_ninja_log_options | length > 0 %}
      options:
{% for key, value in invoice_ninja_log_options.items() %}
        {{ key }}: {{ value | quote }}
{% endfor %}
{% else %}
      options: {}
{% endif %}
{% if invoice_ninja_watchtower_monitor_only | bool %}
    labels:
      com.centurylinklabs.watchtower.monitor-only: "true"
{% endif %}

  {{ invoice_ninja_redis_service_name }}:
    image: {{ invoice_ninja_redis_image | quote }}
    container_name: {{ invoice_ninja_redis_container_name | quote }}
    command:
      - redis-server
      - --appendonly
      - "yes"
    restart: unless-stopped
    volumes:
      - {{ invoice_ninja_data_redis_dir | quote }}:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 15s
      timeout: 5s
      retries: 10
      start_period: 10s
    logging:
      driver: {{ invoice_ninja_log_driver | quote }}
{% if invoice_ninja_log_options | length > 0 %}
      options:
{% for key, value in invoice_ninja_log_options.items() %}
        {{ key }}: {{ value | quote }}
{% endfor %}
{% else %}
      options: {}
{% endif %}
{% if invoice_ninja_watchtower_monitor_only | bool %}
    labels:
      com.centurylinklabs.watchtower.monitor-only: "true"
{% endif %}
